{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JacobSal/quantum-lens/schemas/analysis_record.schema.json",
  "title": "Quantum Lens Analysis Record",
  "description": "Structured source-of-truth record for a /quantum-lens perception analysis. The LLM emits this object; scripts/ql_persist.py validates it, writes the canonical JSON, renders the markdown view, and updates index.json. Prose lives in string fields; structure/headers/tables are rendered deterministically by Python.",
  "type": "object",
  "required": ["kind", "input_title", "insights", "overall_score", "lenses"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "analysis" },
    "record_id": {
      "type": "string",
      "description": "Stable id {date}-{slug}-{8hex}. Generated by ql_persist.py if omitted."
    },
    "date": { "type": "string", "description": "ISO date YYYY-MM-DD. Defaulted by ql_persist.py if omitted." },
    "input_title": { "type": "string", "minLength": 1 },
    "input": { "type": "string", "description": "URL or first ~100 chars of the input" },
    "input_mode": { "type": "string", "enum": ["url", "text", "concept"] },
    "domain": { "type": "string" },
    "depth": { "type": "string", "enum": ["quick", "standard", "deep"] },
    "naive_reading": { "type": "string" },
    "atoms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "tag", "text"],
        "properties": {
          "id": { "type": "string" },
          "tag": { "type": "string", "description": "e.g. claim | assumption | prediction" },
          "text": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "insights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "lens", "breakthrough_score"],
        "properties": {
          "title": { "type": "string" },
          "lens": { "type": "string" },
          "instrument": { "type": "string" },
          "cognitive_mode": { "type": "string" },
          "text": { "type": "string" },
          "evidence_atoms": { "type": "array", "items": { "type": "string" } },
          "action_path": { "type": "string" },
          "breakthrough_score": { "type": "number", "minimum": 1, "maximum": 10 },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "interference": {
      "type": "object",
      "properties": {
        "constructive": { "type": "array", "items": { "type": "string" } },
        "destructive": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_a": { "type": "string" },
              "claim_b": { "type": "string" },
              "crux": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "isomorphisms": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "killer_question": {
      "type": "object",
      "properties": {
        "q": { "type": "string" },
        "why": { "type": "string" },
        "if_yes": { "type": "string" },
        "if_no": { "type": "string" }
      },
      "additionalProperties": true
    },
    "tunnels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "barrier": { "type": "string" },
          "barrier_type": { "type": "string", "enum": ["assumed", "mutable", "temporal", "immutable"] },
          "frame_shift": { "type": "string" },
          "other_side": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "superposition_view": { "type": "array", "items": { "type": "string" } },
    "meta_observations": { "type": "string" },
    "overall_score": { "type": "number", "minimum": 1, "maximum": 10 },
    "lenses": { "type": "array", "items": { "type": "string" } },
    "extended": { "type": "boolean", "default": false },
    "kairn_node_id": { "type": ["string", "null"], "default": null }
  }
}
