{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JacobSal/quantum-lens/schemas/solution_record.schema.json",
  "title": "Quantum Lens Solution Record",
  "description": "Structured source-of-truth record for a /quantum-solve solution-engineering report. The LLM emits this object; scripts/ql_persist.py validates it, writes the canonical JSON, renders the markdown view, and updates index.json.",
  "type": "object",
  "required": ["kind", "input_title", "mode", "executive_summary"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "solution" },
    "record_id": { "type": "string", "description": "Stable id {date}-{slug}-{8hex}. Generated by ql_persist.py if omitted." },
    "date": { "type": "string" },
    "input_title": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "description": "URL or problem description" },
    "mode": { "type": "string", "enum": ["repo", "problem", "contra", "cascade"] },
    "from_ql": { "type": "boolean", "default": false },
    "cascade": { "type": "boolean", "default": false },
    "relevance_score": { "type": ["number", "null"] },
    "maps": {
      "type": "object",
      "properties": {
        "overlap": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "gap": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "collision": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      },
      "additionalProperties": true
    },
    "solution_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "gap": { "type": "string" },
          "approach": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "risk_rollback": { "type": "string" },
          "validation": { "type": "string" },
          "devils_advocate": { "type": "string" },
          "usefulness_band": { "type": "string" },
          "success_band": { "type": "string" },
          "effort": { "type": "string" },
          "priority": { "type": ["string", "number"] }
        },
        "additionalProperties": true
      }
    },
    "reverse_path": {
      "type": "object",
      "properties": {
        "goal": { "type": "string" },
        "table": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "string" },
              "must_be_true": { "type": "string" },
              "current_reality": { "type": "string" },
              "gap": { "type": "string" },
              "barrier_type": { "type": "string", "enum": ["assumed", "mutable", "temporal", "immutable"] }
            },
            "additionalProperties": true
          }
        },
        "barriers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "classification": { "type": "string", "enum": ["assumed", "mutable", "temporal", "immutable"] },
              "lifecycle_stage": { "type": "string" },
              "evidence": { "type": "string" },
              "challenge": { "type": "string" },
              "elimination": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "wavelength_change": { "type": "string" },
        "residual": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "roadmap": {
      "type": "object",
      "properties": {
        "quick_wins": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "main_track": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "deal_breakers": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      },
      "additionalProperties": true
    },
    "open_problems": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "executive_summary": { "type": "string" },
    "usefulness_band": { "type": "string" },
    "success_band": { "type": "string" },
    "action_gate": { "type": "string", "enum": ["auto-plan", "note", "conversational"] },
    "kairn_node_id": { "type": ["string", "null"], "default": null }
  }
}
